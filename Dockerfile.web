# AIgram — FastAPI backend (port 8000 by default)
# Build: docker build -f Dockerfile.web -t aigram-web .
# Run:   docker run -p 8000:8000 --env-file .env aigram-web
#
# Frontend: build separately with VITE_API_URL=http://<host>:8000
#   cd web && npm ci && VITE_API_URL=http://localhost:8000 npm run build

FROM python:3.12-slim-bookworm

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app \
    WEB_PORT=8000 \
    HOST=0.0.0.0

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt

COPY . .

EXPOSE 8000

CMD ["sh", "-c", "uvicorn main:app --host ${HOST} --port ${WEB_PORT}"]
